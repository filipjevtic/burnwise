{
  "name": "burnwise",
  "version": "0.2.0",
  "private": true,
  "description": "Self-hosted, vendor-neutral analytics that attribute AI-assisted effort to tickets, projects, and developers for realistic sprint planning and estimation.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.9.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "allowScripts": {
    "@prisma/client@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true
  },
  "dependencies": {
    "tailwindcss": "^4.3.3"
  }
}
