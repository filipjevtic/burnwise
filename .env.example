# Server
DATABASE_URL=postgresql://ats:ats@localhost:5432/ats
PORT=3000
NODE_ENV=development

# Auth — REQUIRED: set a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Public URL of the web dashboard (used to redirect back after OAuth login)
APP_URL=http://localhost:5173

# Browser origins allowed by CORS in production (comma-separated). Empty
# defaults to APP_URL. Ignored outside production, where any origin is
# reflected for local development.
CORS_ALLOWED_ORIGINS=

# Public URL of THIS server. Used to build the OAuth redirect_uri that must match
# what your IdP has registered. Set to your public domain in production.
SERVER_PUBLIC_URL=http://localhost:3000

# Restrict SSO sign-in / auto-provisioning to specific email domains
# (comma-separated). Empty = allow any domain. e.g. example.com,corp.example.com
SSO_ALLOWED_DOMAINS=

# Allow issue-tracker integration URLs (Jira/GitLab baseUrl) to resolve to
# private IP ranges. Loopback and link-local (cloud metadata) are ALWAYS
# blocked. Set true only for self-hosted trackers on an internal network.
INTEGRATION_ALLOW_PRIVATE_HOSTS=false

# GitHub OAuth (optional) — create at https://github.com/settings/applications/new
# Callback URL: {SERVER_PUBLIC_URL}/api/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (optional) — create at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitLab OAuth (optional) — create at https://gitlab.com/-/user_settings/applications
# Callback URL: http://localhost:3000/api/v1/auth/oauth/gitlab/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# For self-hosted GitLab, set the base URL:
# GITLAB_BASE_URL=https://gitlab.example.com

# Generic OIDC (optional) — connects to Keycloak, Authentik, Okta, Azure AD, etc.
# SSO buttons appear automatically when configured.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=SSO
OIDC_SCOPE=openid email profile

# Ingest API key used by collectors
INGEST_API_KEY=dev-key

# Encryption key for secrets stored at rest (integration tokens, etc.).
# RECOMMENDED in production. 32-byte random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, the server derives a key from JWT_SECRET (fine for dev).
BURNWISE_ENCRYPTION_KEY=

# Shared secret for verifying inbound CI webhooks (GitHub HMAC / GitLab token /
# generic bearer). RECOMMENDED in production. If unset, webhook verification is
# skipped and a warning is logged.
CI_WEBHOOK_SECRET=

# Proxy
SERVER_URL=http://localhost:3000
# Upstream LLM API. OpenAI: https://api.openai.com | Anthropic: https://api.anthropic.com
UPSTREAM_URL=https://api.openai.com
# Fallback provider used only when auto-detection is ambiguous (openai | anthropic).
# The proxy auto-detects the format per request (path / model / auth header).
PROVIDER=openai

# Web
VITE_API_URL=http://localhost:3000

# Collectors (set WORKSPACE_ID and PROJECT_ID after first-run setup)
ATS_SERVER_URL=http://localhost:3000
ATS_INGEST_API_KEY=dev-key
# Personal API key (bw_sk_...) generated in Settings -> API Keys. Preferred over
# the shared ingest key: events bind to the real developer + workspace.
ATS_API_KEY=
ATS_WORKSPACE_ID=
ATS_PROJECT_ID=
ATS_USER_ID=
