# Server
DATABASE_URL=postgresql://ats:ats@localhost:5432/ats
PORT=3000
NODE_ENV=development

# Auth — REQUIRED: set a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Public URL of the web dashboard (used to build OAuth redirect URIs)
APP_URL=http://localhost:5173

# GitHub OAuth (optional) — create at https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (optional) — create at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ingest API key used by collectors
INGEST_API_KEY=dev-key

# Encryption key for secrets stored at rest (integration tokens, etc.).
# RECOMMENDED in production. 32-byte random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, the server derives a key from JWT_SECRET (fine for dev).
BURNWISE_ENCRYPTION_KEY=

# Shared secret for verifying inbound CI webhooks (GitHub HMAC / GitLab token /
# generic bearer). RECOMMENDED in production. If unset, webhook verification is
# skipped and a warning is logged.
CI_WEBHOOK_SECRET=

# Proxy
SERVER_URL=http://localhost:3000
UPSTREAM_URL=https://api.openai.com
PROVIDER=openai

# Web
VITE_API_URL=http://localhost:3000

# Collectors (set WORKSPACE_ID and PROJECT_ID after first-run setup)
ATS_SERVER_URL=http://localhost:3000
ATS_INGEST_API_KEY=dev-key
# Personal API key (bw_sk_...) generated in Settings -> API Keys. Preferred over
# the shared ingest key: events bind to the real developer + workspace.
ATS_API_KEY=
ATS_WORKSPACE_ID=
ATS_PROJECT_ID=
ATS_USER_ID=
