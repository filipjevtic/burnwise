{
  "name": "@burnwise/vscode",
  "displayName": "Burnwise",
  "description": "Tie AI-assisted effort to your tickets for sprint planning.",
  "version": "0.0.1",
  "private": true,
  "publisher": "burnwise",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "burnwise.setTicket",
        "title": "Set Current Ticket",
        "category": "Burnwise"
      },
      {
        "command": "burnwise.getStatus",
        "title": "Show Status",
        "category": "Burnwise"
      }
    ],
    "configuration": {
      "title": "Burnwise",
      "properties": {
        "burnwise.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Server URL for event ingestion"
        },
        "burnwise.ingestApiKey": {
          "type": "string",
          "default": "dev-key",
          "description": "API key for event ingestion"
        },
        "burnwise.workspaceId": {
          "type": "string",
          "default": "default",
          "description": "Workspace ID"
        },
        "burnwise.projectId": {
          "type": "string",
          "default": "default",
          "description": "Project ID"
        },
        "burnwise.userId": {
          "type": "string",
          "default": "default",
          "description": "User ID"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@burnwise/schema": "*"
  }
}
