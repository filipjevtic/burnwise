generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  setupComplete Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  projects      Project[]
  users         User[]
  invites       Invite[]
  apiKeys       ApiKey[]
  sessions      Session[]
}

model Project {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  tokenBudget Int?     // optional token budget per project
  costBudget  Float?   // optional USD cost budget per project
  tokenBudgetAlertThreshold Int? @default(80) // percent at which to alert on token budget
  costBudgetAlertThreshold  Int? @default(80) // percent at which to alert on cost budget
  issueTracker IssueTrackerConfig?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  tickets     Ticket[]
  events      Event[]
  sprints     Sprint[]
  teamMembers TeamMember[]
  invites     Invite[]
  apiKeys     ApiKey[]
  sessions    Session[]

  @@unique([workspaceId, slug])
}

model User {
  id           String   @id @default(uuid())
  workspaceId  String
  email        String
  displayName  String?
  passwordHash String?  // null for SSO-only users
  role         String   @default("member") // admin, member
  ssoProvider  String?  // github, google, etc.
  ssoId        String?  // provider's user ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  events         Event[]
  memberships    TeamMember[]
  createdInvites Invite[]
  apiKeys        ApiKey[]
  sessions       Session[]

  @@unique([workspaceId, email])
}

model TeamMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member") // owner, admin, member, viewer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model IssueTrackerConfig {
  id        String   @id @default(uuid())
  projectId String   @unique
  provider  String   // jira, github, gitlab
  baseUrl   String
  apiToken  String?
  projectKey String?
  repository String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])
}

model Ticket {
  id            String   @id @default(uuid())
  projectId     String
  externalId    String   // e.g., Jira issue key or GitHub issue number
  externalUrl   String?
  title         String
  description   String?
  status        String
  issueType     String?
  storyPoints   Int?
  assigneeId    String?
  sprintId      String?
  labels        String[]
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id])
  sprint        Sprint?  @relation(fields: [sprintId], references: [id])
  events        Event[]
  sessions      Session[]

  @@unique([projectId, externalId])
}

model Sprint {
  id          String   @id @default(uuid())
  projectId   String
  externalId  String?
  name        String
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("future")
  goal        String?
  tokenBudget Int?     // optional token budget for this sprint
  costBudget  Float?   // optional USD cost budget for this sprint
  tokenBudgetAlertThreshold Int? @default(80) // percent at which to alert on token budget
  costBudgetAlertThreshold  Int? @default(80) // percent at which to alert on cost budget
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id])
  tickets     Ticket[]

  @@unique([projectId, externalId])
}

model Invite {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  workspaceId String
  projectId   String
  role        String    @default("member")
  email       String?   // optional: pre-fill invite for a specific address
  createdById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id])
  createdBy   User      @relation(fields: [createdById], references: [id])
}

model Event {
  id            String   @id @default(uuid())
  eventId       String   @unique
  eventType     String
  timestamp     DateTime
  source        String
  workspaceId   String
  projectId     String
  userId        String
  ticketId      String?
  sessionId     String?
  traceId       String?
  spanId        String?
  parentSpanId  String?
  payload       Json
  metadata      Json     @default("{}")
  // Derived fields populated by association service
  associationMethod String?
  associationConfidence Float?
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  ticket        Ticket?  @relation(fields: [ticketId], references: [id])
  session       Session? @relation(fields: [sessionId], references: [id])

  @@index([projectId, ticketId])
  @@index([projectId, timestamp])
  @@index([traceId])
  @@index([sessionId])
}

// A personal/project API key used by collectors to authenticate ingest and
// session calls. Modeled after Langfuse (pk/sk pair, dual hash) + Sentry
// (per-key rate limits, rotation/revoke).
model ApiKey {
  id                  String    @id @default(uuid())
  publicKey           String    @unique // e.g. bw_pk_...
  hashedSecretKey     String    @unique // bcrypt hash for secure compare
  fastHashedSecretKey String    @unique // sha256 hash for O(1) lookup
  displaySecretKey    String            // masked, e.g. bw_sk_...wxyz
  note                String?
  scope               String    @default("workspace") // workspace | project
  workspaceId         String
  projectId           String?
  userId              String
  rateLimitWindow     Int?      // seconds
  rateLimitCount      Int?      // max requests per window
  expiresAt           DateTime?
  isActive            Boolean   @default(true)
  lastUsedAt          DateTime?
  revokedAt           DateTime?
  createdAt           DateTime  @default(now())
  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  project             Project?  @relation(fields: [projectId], references: [id])
  user                User      @relation(fields: [userId], references: [id])

  @@index([workspaceId])
  @@index([userId])
}

// An agent work session: groups events for one developer working a ticket
// over a time window. The session resolves the ticket once; events inherit it.
model Session {
  id          String    @id @default(uuid())
  workspaceId String
  projectId   String
  userId      String
  ticketId    String?
  ticketKey   String?   // raw external key (e.g. PROJ-123), even if not yet synced
  source      String    // proxy, cli, ide-plugin, mcp
  status      String    @default("active") // active | ended
  branch      String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  ticket      Ticket?   @relation(fields: [ticketId], references: [id])
  events      Event[]

  @@index([workspaceId])
  @@index([projectId, status])
  @@index([userId])
}
