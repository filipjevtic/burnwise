{
  "name": "@burnwise/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc && node build.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/services/*.test.ts src/lib/*.test.ts src/integrations/*.test.ts",
    "test:coverage": "c8 node --test dist/services/*.test.js dist/lib/*.test.js dist/integrations/*.test.js"
  },
  "dependencies": {
    "@burnwise/pricing": "*",
    "@burnwise/schema": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.8.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.9.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "c8": "^12.0.0",
    "esbuild": "^0.28.1",
    "prisma": "^7.8.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
